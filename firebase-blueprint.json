{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account metadata stored upon signup",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string" },
        "displayName": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Resume": {
      "title": "User Resume File",
      "description": "Uploaded resume metadata and parsed text content",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "size": { "type": "integer" },
        "type": { "type": "string" },
        "uploadedAt": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["id", "userId", "name", "size", "uploadedAt"]
    },
    "Analysis": {
      "title": "AI Resume Analysis",
      "description": "Resume tailoring suggestions, matching scores, and action items generated by Gemini",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "resumeId": { "type": "string" },
        "resumeName": { "type": "string" },
        "targetCompany": { "type": "string" },
        "targetRole": { "type": "string" },
        "jobDescription": { "type": "string" },
        "createdAt": { "type": "string" },
        "matchingScore": { "type": "integer" },
        "tailoredContent": { "type": "string" },
        "suggestedChanges": { "type": "string" }
      },
      "required": [
        "id",
        "userId",
        "resumeId",
        "resumeName",
        "targetCompany",
        "targetRole",
        "createdAt"
      ]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile collection, identified by authentication UID"
    },
    "/users/{userId}/resumes/{resumeId}": {
      "schema": "Resume",
      "description": "User resumes subcollection, containing parsed contents and metadata"
    },
    "/users/{userId}/analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "User resume tailoring analyses subcollection"
    }
  }
}
